@model ExerciseFormViewModel

@{
    ViewData["Title"] = "Edit Exercise";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start mb-4">
                    <div>
                        <h2 class="mb-1">Edit Exercise</h2>
                        <p class="text-muted mb-0">Update the selected vocabulary exercise.</p>
                    </div>
                    <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
                </div>

                <form asp-action="Edit" method="post">
                    <input asp-for="ExerciseId" type="hidden" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="VocabId" class="form-label"></label>
                        <select asp-for="VocabId" asp-items="Model.VocabularyOptions" class="form-select"></select>
                        <span asp-validation-for="VocabId" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Type" class="form-label"></label>
                        <input asp-for="Type" class="form-control" list="exerciseTypeSuggestions" placeholder="Select or type an exercise type" />
                        <datalist id="exerciseTypeSuggestions">
                            @foreach (var option in Model.TypeOptions)
                            {
                                <option value="@option.Value"></option>
                            }
                        </datalist>
                        <div class="form-text">Suggested values: @string.Join(", ", Model.TypeOptions.Select(option => option.Value))</div>
                        <span asp-validation-for="Type" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="MatchMode" class="form-label"></label>
                        <select asp-for="MatchMode" asp-items="Model.MatchModeOptions" class="form-select"></select>
                        <span asp-validation-for="MatchMode" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="CreatedAt" class="form-label"></label>
                        <input asp-for="CreatedAt" type="datetime-local" asp-format="{0:yyyy-MM-ddTHH:mm}" class="form-control" />
                        <span asp-validation-for="CreatedAt" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Update Exercise</button>
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
