@model IEnumerable<VocabLearning.Models.Exercise>

@{
    ViewData["Title"] = "Exercises";
    var vocabularyNames = ViewBag.VocabularyNames as IDictionary<long, string> ?? new Dictionary<long, string>();
    var totalExercises = Model.Count();
    var distinctTypeCount = Model
        .Select(exercise => exercise.Type)
        .Where(type => !string.IsNullOrWhiteSpace(type))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .Count();
    var coveredVocabularyCount = Model
        .Select(exercise => exercise.VocabId)
        .Distinct()
        .Count();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Exercises</h2>
    <div>
        <a asp-action="Create" class="btn btn-primary">Add Exercise</a>
        <a asp-controller="Admin" asp-action="Index" class="btn btn-secondary">Back to Admin</a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase">Total</div>
                <div class="fs-3 fw-semibold">@totalExercises</div>
                <div class="text-muted">Exercises created</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase">Types</div>
                <div class="fs-3 fw-semibold">@distinctTypeCount</div>
                <div class="text-muted">Distinct exercise types</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase">Coverage</div>
                <div class="fs-3 fw-semibold">@coveredVocabularyCount</div>
                <div class="text-muted">Vocabulary items with exercises</div>
            </div>
        </div>
    </div>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">There are no exercises yet.</div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-striped align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Vocabulary</th>
                        <th>Type</th>
                        <th>Match mode</th>
                        <th>Created At</th>
                        <th class="text-end" style="width: 170px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var exercise in Model)
                {
                    <tr>
                        <td class="fw-semibold">#@exercise.ExerciseId</td>
                        <td>@(vocabularyNames.TryGetValue(exercise.VocabId, out var word) ? word : $"ID {exercise.VocabId}")</td>
                        <td>
                            <span class="badge rounded-pill text-bg-secondary">@exercise.Type</span>
                        </td>
                        <td>@(string.IsNullOrWhiteSpace(exercise.MatchMode) ? "-" : exercise.MatchMode)</td>
                        <td>@exercise.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@exercise.ExerciseId" class="btn btn-sm btn-outline-primary">Edit</a>
                            <a asp-action="Delete" asp-route-id="@exercise.ExerciseId" class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}
