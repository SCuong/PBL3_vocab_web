@model IReadOnlyList<VocabLearning.Models.LearningLog>

@{
    ViewData["Title"] = "Learning History";
}

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div>
                        <h2 class="mb-1">Learning History</h2>
                        <p class="text-muted mb-0">Latest 100 activities.</p>
                    </div>
                    <a asp-controller="Account" asp-action="Profile" class="btn btn-outline-secondary">Back to Profile</a>
                </div>

                @if (!Model.Any())
                {
                    <div class="alert alert-info mb-0">No learning activity yet.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Type</th>
                                    <th>Words</th>
                                    <th>Score</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@item.Date.ToString("yyyy-MM-dd HH:mm")</td>
                                        <td>@item.ActivityType</td>
                                        <td>@item.WordsStudied</td>
                                        <td>@item.Score.ToString("0.#")%</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
