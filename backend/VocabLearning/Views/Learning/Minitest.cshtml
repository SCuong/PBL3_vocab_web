@model LearningMinitestViewModel

@{
    ViewData["Title"] = "Minitest";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
        <h2 class="mb-1">@Model.TopicName</h2>
        <p class="text-muted mb-0">@Model.SessionModeDisplay &middot; @Model.Questions.Count questions</p>
    </div>
    <a asp-action="Study" asp-route-topicId="@Model.TopicId" asp-route-ids="@Model.BatchVocabularyIds" asp-route-index="0" class="btn btn-outline-secondary">Back to Words</a>
</div>

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

<form id="minitest-form" asp-action="Minitest" method="post" class="d-grid gap-3">
    @Html.AntiForgeryToken()
    <input asp-for="TopicId" type="hidden" />
    <input asp-for="ParentTopicId" type="hidden" />
    <input asp-for="TopicName" type="hidden" />
    <input asp-for="BatchVocabularyIds" type="hidden" />
    <input asp-for="SessionMode" type="hidden" />
    <input asp-for="SessionStartedAt" type="hidden" />

    @for (var i = 0; i < Model.Questions.Count; i++)
    {
        <input asp-for="Questions[i].VocabId" type="hidden" />
        <input asp-for="Questions[i].Word" type="hidden" />
        <input asp-for="Questions[i].ExerciseType" type="hidden" />
        <input asp-for="Questions[i].MatchMode" type="hidden" />

        <div class="card learning-quiz-card">
            <div class="card-body">
                <div class="text-uppercase small text-muted mb-2">Question @(i + 1)</div>
                <h4 class="mb-3">@Model.Questions[i].Meaning</h4>

                <div class="d-grid gap-2">
                    @for (var j = 0; j < Model.Questions[i].Options.Count; j++)
                    {
                        var option = Model.Questions[i].Options[j];
                        var radioId = $"question_{i}_option_{j}";

                        <div class="form-check learning-fill-option px-3 py-2">
                            <input class="form-check-input"
                                   type="radio"
                                   id="@radioId"
                                   name="Questions[@i].SelectedAnswer"
                                   value="@option.Value"
                                   @(Model.Questions[i].SelectedAnswer == option.Value ? "checked" : null) />
                            <label class="form-check-label ms-2" for="@radioId">@option.DisplayText</label>
                        </div>
                    }
                </div>

                <div id="question-error-@i" class="text-danger small mt-2 d-none">
                    Please choose one answer for this question.
                </div>
            </div>
        </div>
    }

    <div class="d-flex justify-content-end">
        <button id="submit-minitest" type="submit" class="btn btn-success">Submit Minitest</button>
    </div>
</form>

@section Scripts {
    <script>
        (function () {
            const form = document.getElementById("minitest-form");
            if (!form) {
                return;
            }

            const questionCount = @Model.Questions.Count;

            form.addEventListener("submit", function (event) {
                let hasError = false;
                let firstErrorElement = null;

                for (let i = 0; i < questionCount; i++) {
                    const checked = form.querySelector(`input[name='Questions[${i}].SelectedAnswer']:checked`);
                    const errorElement = document.getElementById(`question-error-${i}`);

                    if (!checked) {
                        hasError = true;
                        if (errorElement) {
                            errorElement.classList.remove("d-none");
                            if (!firstErrorElement) {
                                firstErrorElement = errorElement;
                            }
                        }
                    }
                    else if (errorElement) {
                        errorElement.classList.add("d-none");
                    }
                }

                if (hasError) {
                    event.preventDefault();
                    firstErrorElement?.scrollIntoView({ behavior: "smooth", block: "center" });
                }
            });
        })();
    </script>
}
