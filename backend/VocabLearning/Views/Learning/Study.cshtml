@model LearningStudyViewModel

@{
    ViewData["Title"] = "Study";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
        <h2 class="mb-1">@Model.TopicName</h2>
        <p class="text-muted mb-0">@Model.SessionModeDisplay &middot; Word @Model.DisplayIndex/@Model.TotalWords</p>
    </div>
    <a asp-action="Index" asp-route-parentTopicId="@Model.ParentTopicId" class="btn btn-outline-secondary">Back to Topics</a>
</div>

<div class="progress learning-progress mb-4" role="progressbar" aria-valuenow="@Model.ProgressPercent" aria-valuemin="0" aria-valuemax="100">
    <div class="progress-bar" style="width: @Model.ProgressPercent%;"></div>
</div>

<div class="card learning-study-card shadow-sm">
    <div class="card-body p-4">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-3">
            <div>
                <span class="badge text-bg-primary">@Model.SessionModeDisplay</span>
                @if (!string.IsNullOrWhiteSpace(Model.CurrentWord.Level))
                {
                    <span class="badge text-bg-light border text-dark">@Model.CurrentWord.Level</span>
                }
            </div>

            <div class="text-muted small">@Model.TopicDescription</div>
        </div>

        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-2">
            <h1 class="display-5 mb-0">@Model.CurrentWord.Word</h1>
            <button id="btn-ask-ai" class="btn btn-outline-info btn-sm" data-word="@Model.CurrentWord.Word" data-topic="@Model.TopicName" title="Giải thích bằng AI">
                Hỏi AI ✨
            </button>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.CurrentWord.Ipa))
        {
            <p class="text-muted fs-5 mb-3">@Model.CurrentWord.Ipa</p>
        }

        <div id="ai-response-container" class="d-none mb-4">
            <div class="card border-info">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0 fs-6">Trợ lý AI 🤖</h5>
                </div>
                <div class="card-body">
                    <div id="ai-loading" class="d-none text-center p-2">
                        <div class="spinner-border spinner-border-sm text-info" role="status">
                            <span class="visually-hidden">Đang phân tích...</span>
                        </div>
                        <span class="ms-2 small">Đang phân tích...</span>
                    </div>
                    <div id="ai-result" class="d-none small">
                        <!-- Nội dung AI sẽ được chèn vào đây -->
                    </div>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.CurrentWord.AudioUrl))
        {
            <audio controls preload="metadata" class="mb-4 w-100">
                <source src="@Model.CurrentWord.AudioUrl" type="audio/mpeg" />
            </audio>
        }

        <button type="button" id="show-answer-button" class="btn btn-outline-primary">Show Meaning</button>

        <div id="answer-panel" class="learning-answer-panel d-none mt-4">
            <div class="card border-success-subtle bg-light mb-4">
                <div class="card-body">
                    <h4 class="mb-2">Meaning</h4>
                    <p class="mb-0">@Model.CurrentWord.MeaningVi</p>
                </div>
            </div>

            @if (Model.CurrentWord.Examples.Any())
            {
                <h4>Examples</h4>
                <ul class="learning-example-list">
                    @foreach (var example in Model.CurrentWord.Examples)
                    {
                        <li class="mb-3">
                            <div><b>EN:</b> @example.ExampleEn</div>
                            <div><b>VI:</b> @example.ExampleVi</div>
                            @if (!string.IsNullOrWhiteSpace(example.AudioUrl))
                            {
                                <div>
                                    <a href="@example.AudioUrl" target="_blank" rel="noopener noreferrer">Open example audio</a>
                                </div>
                            }
                        </li>
                    }
                </ul>
            }
        </div>

        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mt-4">
            <div>
                @if (Model.CanGoPrevious)
                {
                    <a asp-action="Study"
                       asp-route-topicId="@Model.TopicId"
                       asp-route-ids="@Model.BatchVocabularyIds"
                       asp-route-index="@(Model.CurrentIndex - 1)"
                       class="btn btn-outline-secondary">
                        Previous Word
                    </a>
                }
            </div>

            <div>
                @if (Model.CanGoNext)
                {
                    <a asp-action="Study"
                       asp-route-topicId="@Model.TopicId"
                       asp-route-ids="@Model.BatchVocabularyIds"
                       asp-route-index="@(Model.CurrentIndex + 1)"
                       class="btn btn-primary">
                        Next Word
                    </a>
                }
                else
                {
                    <a asp-action="Minitest"
                       asp-route-topicId="@Model.TopicId"
                       asp-route-ids="@Model.BatchVocabularyIds"
                       class="btn btn-success">
                        Start Minitest
                    </a>
                }
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script>
        (function () {
            const showAnswerButton = document.getElementById("show-answer-button");
            const answerPanel = document.getElementById("answer-panel");

            if (!showAnswerButton || !answerPanel) {
                return;
            }

            showAnswerButton.addEventListener("click", function () {
                answerPanel.classList.remove("d-none");
                showAnswerButton.classList.add("d-none");
            });

            // AI Assistant Logic
            const btnAskAi = document.getElementById('btn-ask-ai');
            if (btnAskAi) {
                btnAskAi.addEventListener('click', async function () {
                    var btn = this;
                    var word = btn.getAttribute('data-word');
                    var topic = btn.getAttribute('data-topic');
                    var container = document.getElementById('ai-response-container');
                    var loading = document.getElementById('ai-loading');
                    var result = document.getElementById('ai-result');

                    // Show container and loading
                    container.classList.remove('d-none');
                    btn.disabled = true;
                    result.classList.add('d-none');
                    loading.classList.remove('d-none');

                    var formData = new FormData();
                    formData.append('word', word);
                    formData.append('context', topic);

                    var tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
                    if (tokenInput) {
                        formData.append('__RequestVerificationToken', tokenInput.value);
                    }

                    try {
                        var response = await fetch('/AI/Explain', {
                            method: 'POST',
                            body: formData
                        });

                        if (response.ok) {
                            var htmlContent = await response.text();
                            result.innerHTML = htmlContent;
                            result.classList.remove('d-none');
                        } else {
                            result.innerHTML = "<div class='text-danger'>Có lỗi xảy ra khi gọi AI. Vui lòng thử lại.</div>";
                            result.classList.remove('d-none');
                        }
                    } catch (error) {
                        result.innerHTML = "<div class='text-danger'>Lỗi kết nối mạng: " + error.message + "</div>";
                        result.classList.remove('d-none');
                    } finally {
                        loading.classList.add('d-none');
                        btn.disabled = false;
                    }
                });
            }
        })();
    </script>
}
