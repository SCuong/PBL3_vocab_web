@model LearningMinitestViewModel

@{
    ViewData["Title"] = "Exercise";
    var matchingCount = Model.Questions.Count(item => item.IsMatchingQuestion);
    var fillingCount = Model.Questions.Count - matchingCount;
    var totalTaskCount = matchingCount + fillingCount;
    var isMatchingOnly = matchingCount > 0 && fillingCount == 0;
    var questionPayload = Model.Questions.Select((question, index) => new
    {
        index,
        vocabId = question.VocabId,
        word = question.Word,
        meaning = question.Meaning,
        matchPrompt = question.MatchPrompt,
        fillingSentence = question.FillingSentence,
        isMatchingQuestion = question.IsMatchingQuestion,
        options = question.Options.Select(option => new
        {
            displayText = option.DisplayText,
            value = option.Value
        })
    });
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
        <h2 class="mb-1">@Model.TopicName</h2>
        <p class="text-muted mb-0">
            Exercise &middot; @Model.Questions.Count questions
            @if (isMatchingOnly)
            {
                <span>&middot; Completion-only</span>
            }
        </p>
    </div>
    <a asp-action="Index" asp-route-parentTopicId="@Model.ParentTopicId" class="btn btn-outline-secondary">Back to Topics</a>
</div>

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

<form asp-action="Exercise" method="post" class="d-grid gap-3">
    @Html.AntiForgeryToken()
    <input asp-for="TopicId" type="hidden" />
    <input asp-for="ParentTopicId" type="hidden" />
    <input asp-for="TopicName" type="hidden" />
    <input asp-for="BatchVocabularyIds" type="hidden" />
    <input asp-for="SessionMode" type="hidden" />
    <input asp-for="SessionStartedAt" type="hidden" />

    @for (var i = 0; i < Model.Questions.Count; i++)
    {
        <input asp-for="Questions[i].VocabId" type="hidden" />
        <input asp-for="Questions[i].ExerciseType" type="hidden" />
        <input asp-for="Questions[i].MatchMode" type="hidden" />
        <input asp-for="Questions[i].SelectedAnswer" type="hidden" id="selected-answer-@i" />
    }

    <div class="card learning-quiz-card">
        <div class="card-body d-flex flex-wrap justify-content-between align-items-center gap-3">
            <div>
                <div class="text-uppercase small text-muted mb-1">Progress</div>
                <div class="fw-semibold" id="exercise-progress-text">0 / @totalTaskCount</div>
            </div>
            <div class="learning-score-meta">
                <span>Score: <strong id="exercise-score">0</strong></span>
                <span>Streak: <strong id="exercise-streak">0</strong></span>
            </div>
            <div class="learning-timer-pill">
                <span>Time</span>
                <strong id="exercise-timer">30s</strong>
            </div>
        </div>
        <div class="px-3 pb-3">
            <div class="progress learning-progress">
                <div id="exercise-progress-bar" class="progress-bar" role="progressbar" style="width: 0%;" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0"></div>
            </div>
        </div>
    </div>

    <div class="card learning-quiz-card" id="matching-section" @(matchingCount == 0 ? "hidden" : null)>
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
                <h4 class="mb-0">Matching Exercise (5x5)</h4>
                <span class="badge text-bg-info" id="matching-status">0 / @matchingCount matched</span>
            </div>

            <div class="row g-3">
                <div class="col-md-6">
                    <div class="learning-match-list" id="matching-left-list"></div>
                </div>
                <div class="col-md-6">
                    <div class="learning-match-list" id="matching-right-list"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="card learning-quiz-card" id="filling-section" @(fillingCount == 0 ? "hidden" : null)>
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
                <h4 class="mb-0">Filling (Multiple Choice)</h4>
                <span class="badge text-bg-secondary" id="filling-status">Question 0 / @fillingCount</span>
            </div>

            <div id="filling-question-container" class="mb-3"></div>
            <div id="filling-feedback" class="small fw-semibold mb-3"></div>
            <div class="d-flex justify-content-end">
                <button type="button" class="btn btn-outline-primary" id="filling-next-button" disabled>Next</button>
            </div>
        </div>
    </div>

    @if (!isMatchingOnly)
    {
        <div class="d-flex justify-content-end">
            <button type="submit" class="btn btn-success" id="submit-minitest" disabled>Submit Exercise</button>
        </div>
    }
    else
    {
        <button type="button" class="btn btn-success d-none" id="submit-minitest" disabled>Submit Exercise</button>
    }
</form>

@if (isMatchingOnly)
{
    <div class="modal fade" id="matchingCompleteModal" tabindex="-1" aria-labelledby="matchingCompleteModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-sm modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="matchingCompleteModalLabel">Completed</h5>
                </div>
                <div class="modal-body">
                    <p class="mb-1">You have completed the matching exercise.</p>
                    <p class="mb-0">Elapsed time: <strong id="matching-elapsed-time">0s</strong></p>
                </div>
                <div class="modal-footer">
                    <a asp-action="Index" asp-route-parentTopicId="@Model.ParentTopicId" class="btn btn-primary">Back to Topics</a>
                </div>
            </div>
        </div>
    </div>
}

<script id="minitest-data" type="application/json">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(questionPayload))</script>
<script src="~/js/learning-minitest.js" asp-append-version="true"></script>
