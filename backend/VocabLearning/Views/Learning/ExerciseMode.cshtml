@model LearningExerciseSelectionViewModel

@{
    ViewData["Title"] = "Choose Exercise";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
        <h2 class="mb-1">@Model.TopicName</h2>
        <p class="text-muted mb-0">Choose exercise type for @Model.WordCount words.</p>
    </div>

@if (!Model.HasLearnedWords)
{
    <div class="alert alert-warning" role="alert">
        You have not learned any words in this child topic yet.
    </div>
}
    <a asp-action="Index" asp-route-parentTopicId="@Model.ParentTopicId" class="btn btn-outline-secondary">Back to Topics</a>
</div>

@if (!Model.HasLearnedWords)
{
    <div class="modal fade" id="noLearnedWordsModal" tabindex="-1" aria-labelledby="noLearnedWordsModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-sm modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="noLearnedWordsModalLabel">No learned words yet</h5>
                </div>
                <div class="modal-body">
                    You have not learned any vocabulary in this child topic. Do you want to continue exercise or continue learning first?
                </div>
                <div class="modal-footer">
                    <a asp-action="Study"
                       asp-route-topicId="@Model.TopicId"
                       asp-route-ids="@Model.BatchVocabularyIds"
                       class="btn btn-primary">
                        Continue Learning
                    </a>
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Do Exercise</button>
                </div>
            </div>
        </div>
    </div>

    @section Scripts {
        <script>
            (function () {
                const modalElement = document.getElementById("noLearnedWordsModal");
                if (!modalElement || typeof bootstrap === "undefined" || !bootstrap.Modal) {
                    return;
                }

                const modal = new bootstrap.Modal(modalElement, {
                    backdrop: "static",
                    keyboard: false
                });

                modal.show();
            })();
        </script>
    }
}

<div class="row g-3">
    <div class="col-md-6">
        <a asp-action="Exercise"
           asp-route-topicId="@Model.TopicId"
           asp-route-ids="@Model.BatchVocabularyIds"
           asp-route-mode="matching"
           class="text-decoration-none text-reset">
            <div class="card learning-exercise-mode-card h-100">
                <div class="card-body">
                    <h4 class="mb-2">Matching Exercise (5x5)</h4>
                    <p class="text-muted mb-3">Match English words with IPA or meaning. Correct pair turns green, wrong pair shakes red.</p>
                    <span class="btn btn-outline-primary">Start Matching</span>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-6">
        <a asp-action="Exercise"
           asp-route-topicId="@Model.TopicId"
           asp-route-ids="@Model.BatchVocabularyIds"
           asp-route-mode="filling"
           class="text-decoration-none text-reset">
            <div class="card learning-exercise-mode-card h-100">
                <div class="card-body">
                    <h4 class="mb-2">Filling (Multiple Choice)</h4>
                    <p class="text-muted mb-3">Fill the blank from example sentence. Includes timer, next button, and answer feedback.</p>
                    <span class="btn btn-outline-success">Start Filling</span>
                </div>
            </div>
        </a>
    </div>
</div>
