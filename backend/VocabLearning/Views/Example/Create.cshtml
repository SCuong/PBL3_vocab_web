@model ExampleFormViewModel

@{
    ViewData["Title"] = "Add Example";
}

<h2>Add Example</h2>

<form asp-action="Create" method="post">
    <input asp-for="VocabId" type="hidden" />

    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="ExampleEn" class="form-label"></label>
        <textarea asp-for="ExampleEn" class="form-control" rows="3"></textarea>
        <span asp-validation-for="ExampleEn" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ExampleVi" class="form-label"></label>
        <textarea asp-for="ExampleVi" class="form-control" rows="3"></textarea>
        <span asp-validation-for="ExampleVi" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="AudioUrl" class="form-label"></label>
        <input asp-for="AudioUrl" class="form-control" />
        <span asp-validation-for="AudioUrl" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-controller="Vocabulary" asp-action="Detail" asp-route-id="@Model.VocabId" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
