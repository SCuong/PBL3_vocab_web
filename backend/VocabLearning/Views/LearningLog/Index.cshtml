@model IEnumerable<VocabLearning.Models.LearningLog>

@{
    ViewData["Title"] = "Learning Logs";
    var userNames = ViewBag.UserNames as IDictionary<long, string> ?? new Dictionary<long, string>();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Learning Logs</h2>
    <div>
        <a asp-action="Create" class="btn btn-primary">Add Log</a>
        <a asp-controller="Admin" asp-action="Index" class="btn btn-secondary">Back to Admin</a>
    </div>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">There are no learning logs yet.</div>
}
else
{
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>User</th>
                <th>Date</th>
                <th>Activity Type</th>
                <th>Score</th>
                <th style="width: 170px;">Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@(userNames.TryGetValue(item.UserId, out var userName) ? userName : $"ID {item.UserId}")</td>
                <td>@item.Date.ToString("yyyy-MM-dd HH:mm")</td>
                <td>@item.ActivityType</td>
                <td>@item.Score</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.LogId" class="btn btn-sm btn-outline-primary">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.LogId" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
