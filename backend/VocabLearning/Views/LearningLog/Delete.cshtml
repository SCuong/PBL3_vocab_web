@model VocabLearning.Models.LearningLog

@{
    ViewData["Title"] = "Delete Learning Log";
    var userNames = ViewBag.UserNames as IDictionary<long, string> ?? new Dictionary<long, string>();
    var sessionNames = ViewBag.SessionNames as IDictionary<long, string> ?? new Dictionary<long, string>();
}

<h2>Delete Learning Log</h2>

<div class="alert alert-warning">
    This action will remove the selected learning log.
</div>

<dl class="row">
    <dt class="col-sm-2">User</dt>
    <dd class="col-sm-10">@(userNames.TryGetValue(Model.UserId, out var userName) ? userName : $"ID {Model.UserId}")</dd>

    <dt class="col-sm-2">Date</dt>
    <dd class="col-sm-10">@Model.Date.ToString("yyyy-MM-dd HH:mm")</dd>

    <dt class="col-sm-2">Activity Type</dt>
    <dd class="col-sm-10">@Model.ActivityType</dd>

    <dt class="col-sm-2">Session</dt>
    <dd class="col-sm-10">@(sessionNames.TryGetValue(Model.SessionId, out var sessionName) ? sessionName : $"ID {Model.SessionId}")</dd>

    <dt class="col-sm-2">Words</dt>
    <dd class="col-sm-10">@Model.WordsStudied</dd>

    <dt class="col-sm-2">Score</dt>
    <dd class="col-sm-10">@Model.Score.ToString("0.##")%</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" name="id" value="@Model.LogId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
