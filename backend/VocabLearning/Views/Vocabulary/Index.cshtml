@model IEnumerable<VocabLearning.Models.Vocabulary>

@{
    ViewData["Title"] = "Vocabulary";
    var isAdmin = User.IsInRole(UserRoles.Admin);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Vocabulary List</h2>
    @if (isAdmin)
    {
        <a asp-action="Create" class="btn btn-primary">Add Vocabulary</a>
    }
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">There is no vocabulary yet.</div>
}
else
{
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Word</th>
                <th>IPA</th>
                <th>Level</th>
                <th style="width: @(isAdmin ? "220px" : "90px");">Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var vocabulary in Model)
        {
            <tr>
                <td>@vocabulary.Word</td>
                <td>@vocabulary.Ipa</td>
                <td>@vocabulary.Level</td>
                <td>
                    <a asp-action="Detail" asp-route-id="@vocabulary.VocabId" class="btn btn-sm btn-outline-primary">Detail</a>
                    @if (isAdmin)
                    {
                        <a asp-action="Edit" asp-route-id="@vocabulary.VocabId" class="btn btn-sm btn-outline-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@vocabulary.VocabId" class="btn btn-sm btn-outline-danger">Delete</a>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
}
