@model LearningOverviewViewModel

@{
    ViewData["Title"] = "Learning Overview";

    string NextDirection(string column)
    {
        return string.Equals(Model.SortBy, column, StringComparison.OrdinalIgnoreCase)
            && string.Equals(Model.SortDirection, "asc", StringComparison.OrdinalIgnoreCase)
            ? "desc"
            : "asc";
    }

    string SortIndicator(string column)
    {
        if (!string.Equals(Model.SortBy, column, StringComparison.OrdinalIgnoreCase))
        {
            return string.Empty;
        }

        return string.Equals(Model.SortDirection, "asc", StringComparison.OrdinalIgnoreCase) ? "↑" : "↓";
    }
}

<h2 class="mb-4">Learning Overview</h2>

<form method="get" class="card card-body mb-4">
    <input type="hidden" name="sortBy" value="@Model.SortBy" />
    <input type="hidden" name="sortDirection" value="@Model.SortDirection" />
    <input type="hidden" name="pageSize" value="@Model.PageSize" />
    <input type="hidden" name="page" value="1" />
    <div class="row g-3 align-items-end">
        <div class="col-md-3">
            <label asp-for="SelectedUserId" class="form-label">User</label>
            <select asp-for="SelectedUserId" asp-items="Model.UserOptions" class="form-select">
                <option value="">All users</option>
            </select>
        </div>
        <div class="col-md-3">
            <label asp-for="SelectedTopicId" class="form-label">Topic</label>
            <select asp-for="SelectedTopicId" asp-items="Model.TopicOptions" class="form-select">
                <option value="">All topics</option>
            </select>
        </div>
        <div class="col-md-2">
            <label asp-for="FromDate" class="form-label">From date</label>
            <input asp-for="FromDate" type="date" class="form-control" />
        </div>
        <div class="col-md-2">
            <label asp-for="ToDate" class="form-label">To date</label>
            <input asp-for="ToDate" type="date" class="form-control" />
        </div>
        <div class="col-md-2 d-flex gap-2">
            <button type="submit" class="btn btn-primary w-100">Filter</button>
            <a asp-action="LearningOverview" class="btn btn-outline-secondary w-100">Reset</a>
        </div>
    </div>
</form>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small">Active users</div>
                <div class="fs-4 fw-semibold">@Model.ActiveUserCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small">Learned topics</div>
                <div class="fs-4 fw-semibold">@Model.LearnedTopicCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small">Words studied</div>
                <div class="fs-4 fw-semibold">@Model.TotalWordsStudied</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small">Active hours</div>
                <div class="fs-4 fw-semibold">@Model.TotalActiveHours.ToString("0.##")</div>
            </div>
        </div>
    </div>
</div>

@if (!Model.Rows.Any())
{
    <div class="alert alert-info">No learning activity found yet.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead>
                <tr>
                    <th>
                        <a href="@Url.Action("LearningOverview", new { userId = Model.SelectedUserId, topicId = Model.SelectedTopicId, fromDate = Model.FromDate, toDate = Model.ToDate, sortBy = "user", sortDirection = NextDirection("user"), page = 1, pageSize = Model.PageSize })" class="text-decoration-none text-reset">
                            User @SortIndicator("user")
                        </a>
                    </th>
                    <th>
                        <a href="@Url.Action("LearningOverview", new { userId = Model.SelectedUserId, topicId = Model.SelectedTopicId, fromDate = Model.FromDate, toDate = Model.ToDate, sortBy = "topic", sortDirection = NextDirection("topic"), page = 1, pageSize = Model.PageSize })" class="text-decoration-none text-reset">
                            Topic @SortIndicator("topic")
                        </a>
                    </th>
                    <th class="text-end">
                        <a href="@Url.Action("LearningOverview", new { userId = Model.SelectedUserId, topicId = Model.SelectedTopicId, fromDate = Model.FromDate, toDate = Model.ToDate, sortBy = "sessions", sortDirection = NextDirection("sessions"), page = 1, pageSize = Model.PageSize })" class="text-decoration-none text-reset">
                            Sessions @SortIndicator("sessions")
                        </a>
                    </th>
                    <th class="text-end">
                        <a href="@Url.Action("LearningOverview", new { userId = Model.SelectedUserId, topicId = Model.SelectedTopicId, fromDate = Model.FromDate, toDate = Model.ToDate, sortBy = "words", sortDirection = NextDirection("words"), page = 1, pageSize = Model.PageSize })" class="text-decoration-none text-reset">
                            Words Studied @SortIndicator("words")
                        </a>
                    </th>
                    <th class="text-end">
                        <a href="@Url.Action("LearningOverview", new { userId = Model.SelectedUserId, topicId = Model.SelectedTopicId, fromDate = Model.FromDate, toDate = Model.ToDate, sortBy = "activeminutes", sortDirection = NextDirection("activeminutes"), page = 1, pageSize = Model.PageSize })" class="text-decoration-none text-reset">
                            Active Minutes @SortIndicator("activeminutes")
                        </a>
                    </th>
                    <th>
                        <a href="@Url.Action("LearningOverview", new { userId = Model.SelectedUserId, topicId = Model.SelectedTopicId, fromDate = Model.FromDate, toDate = Model.ToDate, sortBy = "firstactivity", sortDirection = NextDirection("firstactivity"), page = 1, pageSize = Model.PageSize })" class="text-decoration-none text-reset">
                            First Activity @SortIndicator("firstactivity")
                        </a>
                    </th>
                    <th>
                        <a href="@Url.Action("LearningOverview", new { userId = Model.SelectedUserId, topicId = Model.SelectedTopicId, fromDate = Model.FromDate, toDate = Model.ToDate, sortBy = "lastactivity", sortDirection = NextDirection("lastactivity"), page = 1, pageSize = Model.PageSize })" class="text-decoration-none text-reset">
                            Last Activity @SortIndicator("lastactivity")
                        </a>
                    </th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.PagedRows)
                {
                    <tr>
                        <td>@row.Username</td>
                        <td>@row.TopicName</td>
                        <td class="text-end">@row.SessionCount</td>
                        <td class="text-end">@row.WordsStudied</td>
                        <td class="text-end">@row.ActiveMinutes.ToString("0.#")</td>
                        <td>@row.FirstActivityAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@row.LastActivityAt.ToString("yyyy-MM-dd HH:mm")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalPages > 1)
    {
        var pageWindow = 2;
        var startPage = Math.Max(1, Model.Page - pageWindow);
        var endPage = Math.Min(Model.TotalPages, Model.Page + pageWindow);

        <nav class="mt-3" aria-label="Learning overview pages">
            <ul class="pagination mb-0">
                <li class="page-item @(Model.Page <= 1 ? "disabled" : string.Empty)">
                    <a class="page-link" href="@Url.Action("LearningOverview", new { userId = Model.SelectedUserId, topicId = Model.SelectedTopicId, fromDate = Model.FromDate, toDate = Model.ToDate, sortBy = Model.SortBy, sortDirection = Model.SortDirection, page = Model.Page - 1, pageSize = Model.PageSize })">Previous</a>
                </li>

                @if (startPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("LearningOverview", new { userId = Model.SelectedUserId, topicId = Model.SelectedTopicId, fromDate = Model.FromDate, toDate = Model.ToDate, sortBy = Model.SortBy, sortDirection = Model.SortDirection, page = 1, pageSize = Model.PageSize })">1</a>
                    </li>

                    @if (startPage > 2)
                    {
                        <li class="page-item disabled"><span class="page-link">…</span></li>
                    }
                }

                @for (var pageIndex = startPage; pageIndex <= endPage; pageIndex++)
                {
                    <li class="page-item @(pageIndex == Model.Page ? "active" : string.Empty)">
                        <a class="page-link" href="@Url.Action("LearningOverview", new { userId = Model.SelectedUserId, topicId = Model.SelectedTopicId, fromDate = Model.FromDate, toDate = Model.ToDate, sortBy = Model.SortBy, sortDirection = Model.SortDirection, page = pageIndex, pageSize = Model.PageSize })">@pageIndex</a>
                    </li>
                }

                @if (endPage < Model.TotalPages)
                {
                    @if (endPage < Model.TotalPages - 1)
                    {
                        <li class="page-item disabled"><span class="page-link">…</span></li>
                    }

                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("LearningOverview", new { userId = Model.SelectedUserId, topicId = Model.SelectedTopicId, fromDate = Model.FromDate, toDate = Model.ToDate, sortBy = Model.SortBy, sortDirection = Model.SortDirection, page = Model.TotalPages, pageSize = Model.PageSize })">@Model.TotalPages</a>
                    </li>
                }

                <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : string.Empty)">
                    <a class="page-link" href="@Url.Action("LearningOverview", new { userId = Model.SelectedUserId, topicId = Model.SelectedTopicId, fromDate = Model.FromDate, toDate = Model.ToDate, sortBy = Model.SortBy, sortDirection = Model.SortDirection, page = Model.Page + 1, pageSize = Model.PageSize })">Next</a>
                </li>
            </ul>
        </nav>
    }
}

<div class="mt-3">
    <a asp-action="Index" class="btn btn-outline-secondary">Back to Admin</a>
</div>
