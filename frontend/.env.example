# Backend URL used by frontend fetch calls.
# Leave empty for local dev — requests go relative and the Vite proxy below
# forwards /api to the local backend. Set only for a non-proxied deployment.
VITE_API_URL=""

# Backend URL for the local Vite /api proxy. Local .NET backend default port.
VITE_API_PROXY_TARGET="http://localhost:5152"

# Google OAuth client id used by Google Identity Services in learner login/register.
VITE_GOOGLE_CLIENT_ID=""

# NOTE: Gemini API key is a server-side secret. Configure it in the backend
# environment (Gemini__ApiKey in backend/VocabLearning .env or as a host env var).
# Do not place it in this file — Vite would bundle it into the client artifact.
