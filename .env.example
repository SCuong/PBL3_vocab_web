# Copy to .env for local Docker or deployment host configuration.

# PostgreSQL
POSTGRES_DB=vocablearning
POSTGRES_USER=vocablearning
POSTGRES_PASSWORD=change-this-postgres-password

# Public origins
FRONTEND_ORIGIN=https://your-vercel-app.vercel.app
BACKEND_PORT=5152

# Email — Resend (preferred; HTTPS API, works on hosts that block SMTP ports e.g. Render Free)
# Get an API key at https://resend.com. From address must use a Resend-verified domain,
# or onboarding@resend.dev for testing.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=VocabLearning

# SMTP (fallback, used only when RESEND_API_KEY is empty; blocked on Render Free)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_ENABLE_SSL=true
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=VocabLearning

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_PATH=/signin-google

# Gemini AI
GEMINI_API_KEY=
