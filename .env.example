# ═══════════════════════════════════════════════════════════════════
#  PBL3 VocabLearning — Environment Variables
#
#  HƯỚNG DẪN:
#    1. Copy file này: cp .env.example .env
#    2. Điền các giá trị bên dưới
#    3. Chạy: docker compose up --build
#
# ═══════════════════════════════════════════════════════════════════

# ── SQL Server ──────────────────────────────────────────────────────
# Mật khẩu SA — phải đủ mạnh (chữ hoa + chữ thường + số + ký tự đặc biệt, ≥8 ký tự)
SA_PASSWORD=VocabLearning@2024!

# ── JWT ─────────────────────────────────────────────────────────────
# Chuỗi bí mật dùng để ký JWT token — đặt ngẫu nhiên, càng dài càng tốt
JWT_SECRET=change-this-to-a-long-random-secret-string-at-least-32-chars

# ── SMTP (Gmail) ────────────────────────────────────────────────────
# Để gửi email quên mật khẩu.
# Với Gmail: bật "App Password" tại https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# ── Google OAuth (tuỳ chọn) ──────────────────────────────────────────
# Để trống nếu không dùng đăng nhập Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Gemini AI ────────────────────────────────────────────────────────
# Lấy API key tại: https://aistudio.google.com/apikey
Gemini__ApiKey=

# ── Port ─────────────────────────────────────────────────────────────
# Port mà người dùng truy cập trên trình duyệt: http://localhost:3000
FRONTEND_PORT=3000
