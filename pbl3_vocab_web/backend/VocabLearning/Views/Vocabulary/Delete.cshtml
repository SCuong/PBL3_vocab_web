@model VocabLearning.Models.Vocabulary

@{
    ViewData["Title"] = "Delete Vocabulary";
}

<h2>Delete Vocabulary</h2>

<div class="alert alert-warning">
    This action will permanently remove the vocabulary and related records.
</div>

<dl class="row">
    <dt class="col-sm-2">Word</dt>
    <dd class="col-sm-10">@Model.Word</dd>

    <dt class="col-sm-2">IPA</dt>
    <dd class="col-sm-10">@Model.Ipa</dd>

    <dt class="col-sm-2">Level</dt>
    <dd class="col-sm-10">@Model.Level</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" name="id" value="@Model.VocabId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
