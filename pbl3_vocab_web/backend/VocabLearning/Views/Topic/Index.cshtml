@model IEnumerable<VocabLearning.Models.Topic>

@{
    ViewData["Title"] = "Topics";
    var topicNames = Model.ToDictionary(topic => topic.TopicId, topic => topic.Name);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Topics</h2>
    <div>
        <a asp-action="Create" class="btn btn-primary">Add Topic</a>
        <a asp-controller="Admin" asp-action="Index" class="btn btn-secondary">Back to Admin</a>
    </div>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">There are no topics yet.</div>
}
else
{
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th>Parent Topic</th>
                <th style="width: 170px;">Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var topic in Model)
        {
            <tr>
                <td>@topic.Name</td>
                <td>@topic.Description</td>
                <td>@(topic.ParentTopicId.HasValue && topicNames.TryGetValue(topic.ParentTopicId.Value, out var parentName) ? parentName : "No parent")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@topic.TopicId" class="btn btn-sm btn-outline-primary">Edit</a>
                    <a asp-action="Delete" asp-route-id="@topic.TopicId" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
