@model IEnumerable<VocabLearning.Models.ExerciseResult>

@{
    ViewData["Title"] = "Exercise Results";
    var userNames = ViewBag.UserNames as IDictionary<long, string> ?? new Dictionary<long, string>();
    var exerciseNames = ViewBag.ExerciseNames as IDictionary<long, string> ?? new Dictionary<long, string>();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Exercise Results</h2>
    <div>
        <a asp-action="Create" class="btn btn-primary">Add Result</a>
        <a asp-controller="Admin" asp-action="Index" class="btn btn-secondary">Back to Admin</a>
    </div>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">There are no exercise results yet.</div>
}
else
{
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Exercise</th>
                <th>User</th>
                <th>Correct</th>
                <th>Answered At</th>
                <th style="width: 170px;">Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@(exerciseNames.TryGetValue(item.ExerciseId, out var question) ? question : $"ID {item.ExerciseId}")</td>
                <td>@(userNames.TryGetValue(item.UserId, out var userName) ? userName : $"ID {item.UserId}")</td>
                <td>@(item.IsCorrect ? "Yes" : "No")</td>
                <td>@item.AnsweredAt.ToString("yyyy-MM-dd HH:mm")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.ResultId" class="btn btn-sm btn-outline-primary">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.ResultId" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
