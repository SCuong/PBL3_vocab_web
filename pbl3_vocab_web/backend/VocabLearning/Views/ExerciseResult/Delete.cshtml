@model VocabLearning.Models.ExerciseResult

@{
    ViewData["Title"] = "Delete Exercise Result";
    var userNames = ViewBag.UserNames as IDictionary<long, string> ?? new Dictionary<long, string>();
    var exerciseNames = ViewBag.ExerciseNames as IDictionary<long, string> ?? new Dictionary<long, string>();
}

<h2>Delete Exercise Result</h2>

<div class="alert alert-warning">
    This action will remove the selected exercise result.
</div>

<dl class="row">
    <dt class="col-sm-2">Exercise</dt>
    <dd class="col-sm-10">@(exerciseNames.TryGetValue(Model.ExerciseId, out var question) ? question : $"ID {Model.ExerciseId}")</dd>

    <dt class="col-sm-2">User</dt>
    <dd class="col-sm-10">@(userNames.TryGetValue(Model.UserId, out var userName) ? userName : $"ID {Model.UserId}")</dd>

    <dt class="col-sm-2">Correct</dt>
    <dd class="col-sm-10">@(Model.IsCorrect ? "Yes" : "No")</dd>

    <dt class="col-sm-2">Answered At</dt>
    <dd class="col-sm-10">@Model.AnsweredAt.ToString("yyyy-MM-dd HH:mm")</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" name="id" value="@Model.ResultId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
