@model ProgressFormViewModel

@{
    ViewData["Title"] = "Edit Progress";
}

<h2>Edit Progress Record</h2>

<form asp-action="Edit" method="post">
    <input asp-for="OriginalUserId" type="hidden" />
    <input asp-for="OriginalVocabId" type="hidden" />

    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="UserId" class="form-label"></label>
        <select asp-for="UserId" asp-items="Model.UserOptions" class="form-select"></select>
        <span asp-validation-for="UserId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="VocabId" class="form-label"></label>
        <select asp-for="VocabId" asp-items="Model.VocabularyOptions" class="form-select"></select>
        <span asp-validation-for="VocabId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="LastReviewDate" class="form-label"></label>
        <input asp-for="LastReviewDate" type="datetime-local" asp-format="{0:yyyy-MM-ddTHH:mm}" class="form-control" />
        <span asp-validation-for="LastReviewDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="NextReviewDate" class="form-label"></label>
        <input asp-for="NextReviewDate" type="datetime-local" asp-format="{0:yyyy-MM-ddTHH:mm}" class="form-control" />
        <span asp-validation-for="NextReviewDate" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Update</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
