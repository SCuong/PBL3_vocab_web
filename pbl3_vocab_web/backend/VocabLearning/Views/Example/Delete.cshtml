@model VocabLearning.Models.Example

@{
    ViewData["Title"] = "Delete Example";
}

<h2>Delete Example</h2>

<div class="alert alert-warning">
    This action will permanently remove the example.
</div>

<dl class="row">
    <dt class="col-sm-2">Sentence</dt>
    <dd class="col-sm-10">@Model.ExampleEn</dd>

    <dt class="col-sm-2">Translation</dt>
    <dd class="col-sm-10">@Model.ExampleVi</dd>

    <dt class="col-sm-2">Audio URL</dt>
    <dd class="col-sm-10">@Model.AudioUrl</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" name="id" value="@Model.ExampleId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-controller="Vocabulary" asp-action="Detail" asp-route-id="@Model.VocabId" class="btn btn-secondary">Cancel</a>
</form>
