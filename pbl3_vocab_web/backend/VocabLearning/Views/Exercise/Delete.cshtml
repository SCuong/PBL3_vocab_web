@model VocabLearning.Models.Exercise

@{
    ViewData["Title"] = "Delete Exercise";
    var vocabularyNames = ViewBag.VocabularyNames as IDictionary<long, string> ?? new Dictionary<long, string>();
}

<h2>Delete Exercise</h2>

<div class="alert alert-warning">
    This action will remove the exercise and all exercise results using it.
</div>

<dl class="row">
    <dt class="col-sm-2">Vocabulary</dt>
    <dd class="col-sm-10">@(vocabularyNames.TryGetValue(Model.VocabId, out var word) ? word : $"ID {Model.VocabId}")</dd>

    <dt class="col-sm-2">Type</dt>
    <dd class="col-sm-10">@Model.Type</dd>

    <dt class="col-sm-2">Created At</dt>
    <dd class="col-sm-10">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" name="id" value="@Model.ExerciseId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
